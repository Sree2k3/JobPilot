# Google Sheet published CSV URL (Phase 1 - Intake Pipeline)
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vS9a.../pub?output=csv

# OpenRouter API key (Phase 3 - LLM agents)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# SMTP credentials (Phase 3 - Email delivery) — use Gmail App Password
# To generate: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_NAME=JobPilot
SMTP_FROM_EMAIL=your-email@gmail.com
